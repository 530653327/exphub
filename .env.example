# ============================================================
# ExpHub 环境变量配置
# 复制此文件为 .env 并修改密码
#   cp .env.example .env
# ============================================================

# MySQL 数据库密码（必填）
EXPHUB_DB_PASSWORD=your_secure_password

# 以下为可选配置，通常不需要修改
# EXPHUB_DB_URL=jdbc:mysql://mysql:3306/exphub?useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true&createDatabaseIfNotExist=true
# EXPHUB_DB_USERNAME=root


